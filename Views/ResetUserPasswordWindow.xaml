<Window x:Class="EmergencySimulator.AdminPanel.Views.ResetUserPasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Сброс пароля пользователя" 
        Height="450" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <!-- Основной стиль для кнопок -->
        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,10"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки сброса пароля -->
        <Style x:Key="ResetButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="#FF9800"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#F57C00"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки отмены -->
        <Style x:Key="CancelButtonStyle" TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
            <Setter Property="Background" Value="#757575"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#616161"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Стиль для кнопки закрытия -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="10" 
            BorderThickness="1" 
            BorderBrush="#DDDDDD">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Direction="270" 
                            ShadowDepth="5" 
                            BlurRadius="15" 
                            Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" 
                    Background="#2E3A47" 
                    CornerRadius="10,10,0,0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="60" Margin="20,0">
                    <TextBlock Text="🔐 СБРОС ПАРОЛЯ ПОЛЬЗОВАТЕЛЯ" 
                             Foreground="White" 
                             FontSize="16" 
                             FontWeight="Bold"
                             VerticalAlignment="Center"/>

                    <Button Content="✕" 
                          Width="40" Height="40"
                          Background="Transparent"
                          Foreground="#666666"
                          BorderThickness="0"
                          FontSize="16"
                          FontWeight="Bold"
                          Cursor="Hand"
                          HorizontalAlignment="Right"
                          Style="{StaticResource CloseButtonStyle}"
                          Click="CancelButton_Click"/>
                </Grid>
            </Border>

            <!-- Содержимое -->
            <StackPanel Grid.Row="1" Margin="30,20">

                <!-- Предупреждение -->
                <Border Background="#FFF3E0" 
                        BorderBrush="#FF9800" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <StackPanel>
                        <TextBlock Text="⚠ ВНИМАНИЕ" 
                                 FontWeight="Bold" 
                                 FontSize="13"
                                 Foreground="#E65100"
                                 Margin="0,0,0,8"/>
                        <TextBlock TextWrapping="Wrap"
                                 FontSize="12"
                                 Foreground="#5D4037">
                            <Run Text="Вы собираетесь сбросить пароль для пользователя. Новый временный пароль будет сгенерирован автоматически."/>
                            <LineBreak/>
                            <LineBreak/>
                            <Run Text="Пожалуйста, передайте новый пароль пользователю безопасным способом."/>
                        </TextBlock>
                    </StackPanel>
                </Border>

                <!-- Информация о пользователе -->
                <Border Background="#E3F2FD" 
                        BorderBrush="#2196F3" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="15"
                        Margin="0,0,0,20">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <TextBlock Grid.Row="0" Grid.Column="0" 
                                 Text="Пользователь:" 
                                 FontWeight="Bold"
                                 Margin="0,0,15,8"/>
                        <TextBlock Grid.Row="0" Grid.Column="1"
                                 x:Name="UserNameText"
                                 Text="Иванов Иван Иванович" 
                                 FontSize="14"
                                 Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="1" Grid.Column="0"
                                 Text="Должность:" 
                                 FontWeight="Bold"
                                 Margin="0,0,15,8"/>
                        <TextBlock Grid.Row="1" Grid.Column="1"
                                 x:Name="UserPositionText"
                                 Text="Инженер" 
                                 Margin="0,0,0,8"/>

                        <TextBlock Grid.Row="2" Grid.Column="0"
                                 Text="Создан:" 
                                 FontWeight="Bold"
                                 Margin="0,0,15,0"/>
                        <TextBlock Grid.Row="2" Grid.Column="1"
                                 x:Name="UserCreatedText"
                                 Text="01.01.2024"/>
                    </Grid>
                </Border>

                <!-- Опция отправки уведомления -->
                <CheckBox x:Name="NotifyUserCheckBox"
                        Content="Отправить уведомление пользователю (если указан email)"
                        IsChecked="True"
                        Margin="0,0,0,10"/>

            </StackPanel>

            <!-- Кнопки -->
            <Border Grid.Row="2" 
                    Background="#F5F5F5" 
                    BorderBrush="#DDDDDD" 
                    BorderThickness="0,1,0,0" 
                    CornerRadius="0,0,10,10"
                    Padding="20,15">
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Content="🔄 Сбросить пароль" 
                          Style="{StaticResource ResetButtonStyle}"
                          Click="ResetButton_Click"/>

                    <Button Content="✖ Отмена" 
                          Style="{StaticResource CancelButtonStyle}"
                          Click="CancelButton_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Border>
</Window>
