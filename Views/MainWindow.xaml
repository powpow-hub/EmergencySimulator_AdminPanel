<Window x:Class="EmergencySimulator.AdminPanel.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:EmergencySimulator.AdminPanel.ViewModels"
        xmlns:views="clr-namespace:EmergencySimulator.AdminPanel.Views"
        mc:Ignorable="d"
        Title="Панель администратора - Тренажёр действий при аварии" 
        Height="800" Width="1400" 
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:UsersViewModel}">
            <views:UsersView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:StaffViewModel}">
            <views:StaffView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:PLAViewModel}">
            <views:PLAView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:TrainingResultsViewModel}">
            <views:TrainingResultsView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:EquipmentViewModel}">
            <views:EquipmentView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:VGKViewModel}">
            <views:VGKView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:NotificationListsViewModel}">
            <views:NotificationListsView/>
        </DataTemplate>

        <!-- Стиль для кнопок навигации -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#2E3A47"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="20,15"/>
            <Setter Property="Margin" Value="0,0,0,5"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                BorderThickness="{TemplateBinding BorderThickness}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                            VerticalAlignment="Center"
                                            Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#3A4A5A"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="250"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Панель навигации -->
        <Border Grid.Column="0" Background="#1E2A35" BorderThickness="0,0,1,0" BorderBrush="#3A4A5A">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Меню навигации -->
                <ScrollViewer Grid.Row="0" VerticalScrollBarVisibility="Auto">
                    <StackPanel Margin="10">
                        <TextBlock Text="ПАНЕЛЬ УПРАВЛЕНИЯ" 
                                  FontSize="16" 
                                  FontWeight="Bold" 
                                  Foreground="White" 
                                  Margin="10,20,10,30"
                                  TextAlignment="Center"/>

                        <Button Content="👤 Пользователи" 
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToUsersCommand}"/>

                        <Button Content="👥 Персонал" 
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToStaffCommand}"/>

                        <Button Content="📋 ПЛА" 
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToPLACommand}"/>

                        <Button Content="📊 Результаты тренировок" 
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToTrainingResultsCommand}"/>

                        <Button Content="🔧 Оборудование" 
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToEquipmentCommand}"/>

                        <Button Content="🚒 Состав ВГК" 
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToVGKCommand}"/>

                        <Button Content="📢 Списки оповещения" 
                                Style="{StaticResource NavButtonStyle}"
                                Command="{Binding NavigateToNotificationListsCommand}"/>

                        <!-- Разделитель -->
                        <Border Height="1" 
                                Background="#3A4A5A" 
                                Margin="5,10,5,10"/>

                        <!-- Настройки безопасности -->
                        <Button Content="🔐 Изменить пароль" 
                                Style="{StaticResource NavButtonStyle}"
                                Click="ChangePasswordButton_Click"/>
                    </StackPanel>
                </ScrollViewer>

                <!-- Панель администратора и версия -->
                <StackPanel Grid.Row="1" Margin="10,0,10,10">
                    <!-- Информация об администраторе -->
                    <Border Background="#1A2530" 
                            Padding="12" 
                            Margin="0,0,0,10"
                            CornerRadius="5">
                        <StackPanel>
                            <TextBlock Text="👤 АДМИНИСТРАТОР" 
                                      FontSize="10" 
                                      FontWeight="Bold" 
                                      Foreground="#7A8A9A" 
                                      Margin="0,0,0,10"
                                      TextAlignment="Center"/>

                            <Border Background="#2E3A47" 
                                    Padding="8" 
                                    CornerRadius="3"
                                    Margin="0,0,0,8">
                                <TextBlock x:Name="AdminNameText"
                                          Text="Администратор" 
                                          FontSize="13" 
                                          FontWeight="SemiBold"
                                          Foreground="White" 
                                          TextWrapping="Wrap"
                                          TextAlignment="Center"/>
                            </Border>

                            <TextBlock x:Name="AdminUsernameText"
                                      Text="@admin" 
                                      FontSize="11" 
                                      Foreground="#7A8A9A" 
                                      TextAlignment="Center"
                                      Margin="0,0,0,12"/>

                            <!-- Кнопка выхода -->
                            <Button Content="🚪 Выход из системы" 
                                    Click="LogoutButton_Click"
                                    FontSize="12"
                                    Padding="12,10"
                                    Margin="0">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource NavButtonStyle}">
                                        <Setter Property="Background" Value="#D32F2F"/>
                                        <Setter Property="HorizontalContentAlignment" Value="Center"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="#B71C1C"/>
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Border>

                    <!-- Версия приложения -->
                    <TextBlock Text="Версия 1.0.0" 
                              FontSize="10" 
                              Foreground="#7A8A9A" 
                              TextAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Область контента -->
        <Border Grid.Column="1" Background="#F5F5F5">
            <ContentControl Content="{Binding CurrentViewModel}" Margin="20"/>
        </Border>
    </Grid>
</Window>
