<Window x:Class="EmergencySimulator.AdminPanel.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Вход в панель администратора" 
        Height="570" Width="450"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="PlaceholderTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="PlaceholderPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="15,12"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="LoginButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,15"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="10" 
            BorderThickness="1" 
            BorderBrush="#DDDDDD">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Direction="270" 
                            ShadowDepth="5" 
                            BlurRadius="15" 
                            Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок с кнопкой закрытия -->
            <Border Grid.Row="0" 
                    Background="#2E3A47" 
                    CornerRadius="10,10,0,0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="50">
                    <TextBlock Text="🔐 ВХОД В СИСТЕМУ" 
                             Foreground="White" 
                             FontSize="16" 
                             FontWeight="Bold" 
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Center"/>

                    <Button Content="✕" 
                          Style="{StaticResource CloseButton}"
                          HorizontalAlignment="Right"
                          Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Основное содержимое -->
            <Grid Grid.Row="1" Margin="40,30">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <!-- Иконка -->
                <Viewbox Grid.Row="0" Width="80" Height="80" Margin="0,0,0,30">
                    <Canvas Width="100" Height="100">
                        <Ellipse Width="100" Height="100" Fill="#E3F2FD"/>
                        <Path Stroke="#007ACC" StrokeThickness="4">
                            <Path.Data>
                                <PathGeometry>
                                    <PathFigure StartPoint="50,30">
                                        <LineSegment Point="50,55"/>
                                    </PathFigure>
                                    <PathFigure StartPoint="35,45">
                                        <LineSegment Point="50,55"/>
                                        <LineSegment Point="65,45"/>
                                    </PathFigure>
                                </PathGeometry>
                            </Path.Data>
                            <Path.Style>
                                <Style TargetType="Path">
                                    <Setter Property="StrokeStartLineCap" Value="Round"/>
                                    <Setter Property="StrokeEndLineCap" Value="Round"/>
                                    <Setter Property="StrokeLineJoin" Value="Round"/>
                                </Style>
                            </Path.Style>
                        </Path>
                        <Ellipse Canvas.Left="30" Canvas.Top="60" 
                                Width="40" Height="25" 
                                Fill="Transparent" 
                                Stroke="#007ACC" 
                                StrokeThickness="4"/>
                    </Canvas>
                </Viewbox>

                <!-- Приветствие -->
                <TextBlock Grid.Row="1" 
                         Text="Панель администратора" 
                         FontSize="24" 
                         FontWeight="Bold" 
                         HorizontalAlignment="Center" 
                         Margin="0,0,0,5"/>

                <TextBlock Grid.Row="2" 
                         Text="Введите учетные данные для входа" 
                         FontSize="13" 
                         Foreground="#666666" 
                         HorizontalAlignment="Center" 
                         Margin="0,0,0,30"/>

                <!-- Поле логина -->
                <StackPanel Grid.Row="3" Margin="0,0,0,15">
                    <TextBlock Text="Имя пользователя" 
                             FontSize="13" 
                             Foreground="#666666" 
                             Margin="0,0,0,8"/>
                    <TextBox x:Name="UsernameTextBox"
                           Style="{StaticResource PlaceholderTextBox}"
                           KeyDown="InputField_KeyDown"/>
                </StackPanel>

                <!-- Поле пароля -->
                <StackPanel Grid.Row="4" Margin="0,0,0,20">
                    <TextBlock Text="Пароль" 
                             FontSize="13" 
                             Foreground="#666666" 
                             Margin="0,0,0,8"/>
                    <PasswordBox x:Name="PasswordBox"
                               Style="{StaticResource PlaceholderPasswordBox}"
                               KeyDown="InputField_KeyDown"/>
                </StackPanel>

                <!-- Сообщение об ошибке -->
                <Border Grid.Row="5" 
                        x:Name="ErrorPanel"
                        Background="#FFEBEE" 
                        BorderBrush="#F44336" 
                        BorderThickness="1" 
                        CornerRadius="5" 
                        Padding="12,10"
                        Margin="0,0,0,20"
                        Visibility="Collapsed">
                    <TextBlock x:Name="ErrorMessage" 
                             Text="Неверное имя пользователя или пароль" 
                             Foreground="#D32F2F" 
                             FontSize="12" 
                             TextWrapping="Wrap"/>
                </Border>

                <!-- Кнопка входа -->
                <Button Grid.Row="6" 
                      Content="Войти" 
                      Style="{StaticResource LoginButton}"
                      Click="LoginButton_Click"
                      VerticalAlignment="Top"/>
            </Grid>
        </Grid>
    </Border>
</Window>
