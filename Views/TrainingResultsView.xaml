<UserControl x:Class="EmergencySimulator.AdminPanel.Views.TrainingResultsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:converters="clr-namespace:EmergencySimulator.AdminPanel.Converters"
             mc:Ignorable="d" 
             d:DesignHeight="750" d:DesignWidth="1100">

    <UserControl.Resources>
        <!-- Конвертеры -->
        <converters:ScoreToColorConverter x:Key="ScoreToColor"/>
        <converters:ErrorCountToColorConverter x:Key="ErrorCountToColor"/>
        <converters:StatusToColorConverter x:Key="StatusToColor"/>
        <converters:DateTimeToStringConverter x:Key="DateTimeToString"/>

        <Style x:Key="ButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="15,8"/>
            <Setter Property="Margin" Value="5"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" Margin="{TemplateBinding Padding}"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Панель поиска и фильтров -->
        <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,0,15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBox Grid.Column="0" Text="{Binding SearchText, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="14" Padding="10" VerticalContentAlignment="Center"
                             BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBox.Style>
                            <Style TargetType="TextBox">
                                <Style.Triggers>
                                    <Trigger Property="Text" Value="">
                                        <Setter Property="Background">
                                            <Setter.Value>
                                                <VisualBrush Stretch="None" AlignmentX="Left">
                                                    <VisualBrush.Visual>
                                                        <TextBlock Text="🔍 Поиск по пользователю или статусу..." Foreground="#999999" Margin="5,0,0,0"/>
                                                    </VisualBrush.Visual>
                                                </VisualBrush>
                                            </Setter.Value>
                                        </Setter>
                                    </Trigger>
                                </Style.Triggers>
                            </Style>
                        </TextBox.Style>
                    </TextBox>

                    <Button Grid.Column="1" Content="🔄 Обновить" Style="{StaticResource ButtonStyle}" Command="{Binding RefreshCommand}"/>
                </Grid>

                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                    <TextBlock Text="Дата с:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding StartDate}" Width="150" Margin="0,0,20,0"/>
                    <TextBlock Text="Дата по:" VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <DatePicker SelectedDate="{Binding EndDate}" Width="150" Margin="0,0,20,0"/>
                    <Button Content="Очистить фильтры" Style="{StaticResource ButtonStyle}" Command="{Binding ClearFiltersCommand}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Таблица результатов -->
        <DataGrid Grid.Row="2" ItemsSource="{Binding TrainingResults}" SelectedItem="{Binding SelectedResult}"
                  AutoGenerateColumns="False" CanUserAddRows="False" CanUserDeleteRows="False"
                  SelectionMode="Single" IsReadOnly="True" GridLinesVisibility="Horizontal"
                  AlternatingRowBackground="#F9F9F9" BorderBrush="#DDDDDD" BorderThickness="1" RowHeight="45">

            <DataGrid.Columns>
                <DataGridTextColumn Header="ID" Binding="{Binding ResultID}" Width="50">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Пользователь" Binding="{Binding User.Surname}" Width="130"/>
                <DataGridTextColumn Header="Имя" Binding="{Binding User.Name}" Width="120"/>

                <!-- Начало с форматированием -->
                <DataGridTextColumn Header="Начало" Width="130">
                    <DataGridTextColumn.Binding>
                        <Binding Path="SessionStart" Converter="{StaticResource DateTimeToString}" ConverterParameter="dd.MM.yyyy HH:mm"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>

                <!-- Окончание с форматированием -->
                <DataGridTextColumn Header="Окончание" Width="130">
                    <DataGridTextColumn.Binding>
                        <Binding Path="SessionEnd" Converter="{StaticResource DateTimeToString}" ConverterParameter="dd.MM.yyyy HH:mm"/>
                    </DataGridTextColumn.Binding>
                </DataGridTextColumn>

                <!-- Баллы с цветом -->
                <DataGridTextColumn Header="Баллы" Binding="{Binding TotalScore}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{Binding TotalScore, Converter={StaticResource ScoreToColor}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Критические ошибки с цветом -->
                <DataGridTextColumn Header="Крит. ошибки" Binding="{Binding CriticalErrorsCount}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{Binding CriticalErrorsCount, Converter={StaticResource ErrorCountToColor}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Значительные ошибки с цветом -->
                <DataGridTextColumn Header="Знач. ошибки" Binding="{Binding SignificantErrorsCount}" Width="90">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="Bold"/>
                            <Setter Property="Foreground" Value="{Binding SignificantErrorsCount, Converter={StaticResource ErrorCountToColor}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <DataGridTextColumn Header="Время" Binding="{Binding TimeViolationsCount}" Width="70">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>

                <!-- Статус с цветом -->
                <DataGridTextColumn Header="Статус" Binding="{Binding Status}" Width="*">
                    <DataGridTextColumn.ElementStyle>
                        <Style TargetType="TextBlock">
                            <Setter Property="HorizontalAlignment" Value="Center"/>
                            <Setter Property="FontWeight" Value="SemiBold"/>
                            <Setter Property="Foreground" Value="{Binding Status, Converter={StaticResource StatusToColor}}"/>
                        </Style>
                    </DataGridTextColumn.ElementStyle>
                </DataGridTextColumn>
            </DataGrid.Columns>

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#2E3A47"/>
                    <Setter Property="Foreground" Value="White"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>
        </DataGrid>

        <!-- Панель управления -->
        <Border Grid.Row="3" Background="White" BorderBrush="#DDDDDD" BorderThickness="1,1,1,0" Padding="15">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button Content="📄 Детали" Style="{StaticResource ButtonStyle}" Command="{Binding ViewDetailsCommand}"/>
                <Button Content="📊 Экспорт" Style="{StaticResource ButtonStyle}" Command="{Binding ExportCommand}"/>
                <Button Content="❌ Удалить" Command="{Binding DeleteResultCommand}">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource ButtonStyle}">
                            <Setter Property="Background" Value="#D13438"/>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#B12A2E"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
