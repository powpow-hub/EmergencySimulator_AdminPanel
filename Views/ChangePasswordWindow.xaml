<Window x:Class="EmergencySimulator.AdminPanel.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="Изменение учетных данных" 
        Height="700" Width="500"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize">

    <Window.Resources>
        <Style x:Key="InputTextBox" TargetType="TextBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="InputPasswordBox" TargetType="PasswordBox">
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="Padding" Value="12,10"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#DDDDDD"/>
            <Setter Property="Background" Value="White"/>
            <Style.Triggers>
                <Trigger Property="IsFocused" Value="True">
                    <Setter Property="BorderBrush" Value="#007ACC"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ActionButton" TargetType="Button">
            <Setter Property="Background" Value="#007ACC"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="Padding" Value="0,12"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" 
                                CornerRadius="5">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#005A9E"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Background" Value="#CCCCCC"/>
                    <Setter Property="Foreground" Value="#999999"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CancelButton" TargetType="Button" BasedOn="{StaticResource ActionButton}">
            <Setter Property="Background" Value="#E0E0E0"/>
            <Setter Property="Foreground" Value="#333333"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#BDBDBD"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="CloseButton" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#666666"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Width" Value="40"/>
            <Setter Property="Height" Value="40"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" 
                                            VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="#FFEBEE"/>
                    <Setter Property="Foreground" Value="#D32F2F"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Border Background="White" 
            CornerRadius="10" 
            BorderThickness="1" 
            BorderBrush="#DDDDDD">
        <Border.Effect>
            <DropShadowEffect Color="Black" 
                            Direction="270" 
                            ShadowDepth="5" 
                            BlurRadius="15" 
                            Opacity="0.3"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Заголовок -->
            <Border Grid.Row="0" 
                    Background="#2E3A47" 
                    CornerRadius="10,10,0,0" 
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown">
                <Grid Height="50">
                    <TextBlock Text="🔐 ИЗМЕНЕНИЕ УЧЕТНЫХ ДАННЫХ" 
                             Foreground="White" 
                             FontSize="16" 
                             FontWeight="Bold" 
                             VerticalAlignment="Center" 
                             HorizontalAlignment="Center"/>

                    <Button x:Name="CloseBtn"
                          Content="✕" 
                          Style="{StaticResource CloseButton}"
                          HorizontalAlignment="Right"
                          Click="CloseButton_Click"/>
                </Grid>
            </Border>

            <!-- Содержимое -->
            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel Margin="40,30">

                    <!-- Предупреждение -->
                    <Border x:Name="WarningPanel"
                            Background="#FFF3E0" 
                            BorderBrush="#FF9800" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="15"
                            Margin="0,0,0,25"
                            Visibility="Collapsed">
                        <StackPanel>
                            <TextBlock Text="⚠ ПЕРВЫЙ ВХОД В СИСТЕМУ" 
                                     FontWeight="Bold" 
                                     FontSize="13"
                                     Foreground="#E65100"
                                     Margin="0,0,0,8"/>
                            <TextBlock Text="Для безопасности системы необходимо изменить учетные данные администратора по умолчанию." 
                                     TextWrapping="Wrap"
                                     FontSize="12"
                                     Foreground="#5D4037"/>
                        </StackPanel>
                    </Border>

                    <!-- Текущий пользователь -->
                    <Border Background="#E3F2FD" 
                            BorderBrush="#2196F3" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="15"
                            Margin="0,0,0,25">
                        <StackPanel>
                            <TextBlock Text="Текущий администратор:" 
                                     FontSize="12" 
                                     Foreground="#666666"
                                     Margin="0,0,0,8"/>
                            <TextBlock x:Name="CurrentUserText"
                                     Text="admin" 
                                     FontSize="16" 
                                     FontWeight="Bold"
                                     Foreground="#1976D2"/>
                        </StackPanel>
                    </Border>

                    <!-- Новый логин -->
                    <TextBlock Text="Новый логин:" 
                             FontSize="13" 
                             FontWeight="SemiBold"
                             Foreground="#333333" 
                             Margin="0,0,0,8"/>
                    <TextBox x:Name="NewUsernameTextBox"
                           Style="{StaticResource InputTextBox}"
                           Margin="0,0,0,20"/>

                    <!-- Старый пароль -->
                    <TextBlock Text="Текущий пароль:" 
                             FontSize="13" 
                             FontWeight="SemiBold"
                             Foreground="#333333" 
                             Margin="0,0,0,8"/>
                    <PasswordBox x:Name="OldPasswordBox"
                               Style="{StaticResource InputPasswordBox}"
                               Margin="0,0,0,20"/>

                    <!-- Новый пароль -->
                    <TextBlock Text="Новый пароль:" 
                             FontSize="13" 
                             FontWeight="SemiBold"
                             Foreground="#333333" 
                             Margin="0,0,0,8"/>
                    <PasswordBox x:Name="NewPasswordBox"
                               Style="{StaticResource InputPasswordBox}"
                               Margin="0,0,0,20"/>

                    <!-- Подтверждение пароля -->
                    <TextBlock Text="Подтвердите новый пароль:" 
                             FontSize="13" 
                             FontWeight="SemiBold"
                             Foreground="#333333" 
                             Margin="0,0,0,8"/>
                    <PasswordBox x:Name="ConfirmPasswordBox"
                               Style="{StaticResource InputPasswordBox}"
                               Margin="0,0,0,20"/>

                    <!-- Требования к паролю -->
                    <Border Background="#F5F5F5" 
                            BorderBrush="#E0E0E0" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="12"
                            Margin="0,0,0,20">
                        <StackPanel>
                            <TextBlock Text="Требования к паролю:" 
                                     FontSize="11" 
                                     FontWeight="Bold"
                                     Foreground="#666666"
                                     Margin="0,0,0,8"/>
                            <TextBlock FontSize="11" Foreground="#666666">
                                <Run Text="• Минимум 6 символов"/>
                                <LineBreak/>
                                <Run Text="• Рекомендуется использовать буквы и цифры"/>
                                <LineBreak/>
                                <Run Text="• Избегайте простых паролей (123456, password и т.д.)"/>
                            </TextBlock>
                        </StackPanel>
                    </Border>

                    <!-- Сообщение об ошибке -->
                    <Border x:Name="ErrorPanel"
                            Background="#FFEBEE" 
                            BorderBrush="#F44336" 
                            BorderThickness="1" 
                            CornerRadius="5" 
                            Padding="12"
                            Margin="0,0,0,20"
                            Visibility="Collapsed">
                        <TextBlock x:Name="ErrorMessage" 
                                 Text="Ошибка" 
                                 Foreground="#D32F2F" 
                                 FontSize="12" 
                                 TextWrapping="Wrap"/>
                    </Border>

                    <!-- Кнопки -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Button Grid.Column="0"
                              Content="ОТМЕНА" 
                              Style="{StaticResource CancelButton}"
                              Click="CancelButton_Click"/>

                        <Button Grid.Column="2"
                              Content="СОХРАНИТЬ" 
                              Style="{StaticResource ActionButton}"
                              Click="SaveButton_Click"/>
                    </Grid>

                </StackPanel>
            </ScrollViewer>
        </Grid>
    </Border>
</Window>
